{
  "name": "@rails-ai-build/sdk",
  "version": "0.2.0",
  "description": "Cursor-like AI coding agents for Node.js and any JavaScript project",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "rails-ai-build": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agent", "cursor", "coding", "llm", "openai", "anthropic"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
