<style>
  /* Cursor-inspired themes — dark (default), light, enterprise */
  :root, [data-theme="dark"] {
    --rab-brand: #e11d48;
    --rab-accent: #38bdf8;
    --rab-accent-hover: #7dd3fc;
    --rab-bg: #0b1220;
    --rab-surface: #111827;
    --rab-panel: #0f172a;
    --rab-elevated: #1e293b;
    --rab-border: #334155;
    --rab-text: #e2e8f0;
    --rab-muted: #94a3b8;
    --rab-green: #34d399;
    --rab-yellow: #fbbf24;
    --rab-blue: #60a5fa;
    --rab-purple: #c084fc;
    --rab-red: #fb7185;
    --rab-editor-bg: #020617;
    --rab-input-bg: #020617;
    --rab-github: #238636;
    --rab-enterprise: #a78bfa;
    --rab-font-ui: "IBM Plex Sans", "Segoe UI", sans-serif;
    --rab-font-mono: "JetBrains Mono", "SF Mono", "Fira Code", ui-monospace, monospace;
  }

  [data-theme="light"] {
    --rab-brand: #be123c;
    --rab-accent: #0284c7;
    --rab-bg: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
    --rab-surface: #ffffff;
    --rab-panel: #f8fafc;
    --rab-elevated: #f1f5f9;
    --rab-border: #cbd5e1;
    --rab-text: #0f172a;
    --rab-muted: #64748b;
    --rab-editor-bg: #ffffff;
    --rab-input-bg: #ffffff;
  }

  [data-theme="midnight"] {
    --rab-brand: #22d3ee;
    --rab-accent: #22d3ee;
    --rab-accent-hover: #67e8f9;
    --rab-bg: #020617;
    --rab-surface: #0b1120;
    --rab-panel: #0f172a;
    --rab-elevated: #1e293b;
    --rab-border: #1e3a5f;
    --rab-text: #e0f2fe;
    --rab-muted: #7dd3fc;
    --rab-editor-bg: #020617;
    --rab-input-bg: #020617;
  }

  [data-theme="forest"] {
    --rab-brand: #4ade80;
    --rab-accent: #34d399;
    --rab-accent-hover: #6ee7b7;
    --rab-bg: #071a12;
    --rab-surface: #0c2418;
    --rab-panel: #11301f;
    --rab-elevated: #1a3d2a;
    --rab-border: #24553a;
    --rab-text: #ecfdf5;
    --rab-muted: #86efac;
    --rab-editor-bg: #04140d;
    --rab-input-bg: #04140d;
    --rab-enterprise: #fbbf24;
  }

  [data-theme="slate"] {
    --rab-brand: #38bdf8;
    --rab-accent: #0ea5e9;
    --rab-accent-hover: #38bdf8;
    --rab-bg: linear-gradient(165deg, #1e293b 0%, #0f172a 55%, #020617 100%);
    --rab-surface: #1e293b;
    --rab-panel: #273449;
    --rab-elevated: #334155;
    --rab-border: #475569;
    --rab-text: #f1f5f9;
    --rab-muted: #94a3b8;
    --rab-editor-bg: #0f172a;
    --rab-input-bg: #0f172a;
    --rab-enterprise: #f59e0b;
  }

  /* Back-compat aliases for saved localStorage themes */
  [data-theme="sand"] {
    --rab-brand: #4ade80;
    --rab-accent: #34d399;
    --rab-accent-hover: #6ee7b7;
    --rab-bg: #071a12;
    --rab-surface: #0c2418;
    --rab-panel: #11301f;
    --rab-elevated: #1a3d2a;
    --rab-border: #24553a;
    --rab-text: #ecfdf5;
    --rab-muted: #86efac;
    --rab-editor-bg: #04140d;
    --rab-input-bg: #04140d;
  }

  [data-theme="enterprise"] {
    --rab-brand: #38bdf8;
    --rab-accent: #0ea5e9;
    --rab-accent-hover: #38bdf8;
    --rab-bg: #0f172a;
    --rab-surface: #1e293b;
    --rab-panel: #273449;
    --rab-elevated: #334155;
    --rab-border: #475569;
    --rab-text: #f1f5f9;
    --rab-muted: #94a3b8;
    --rab-editor-bg: #0f172a;
    --rab-input-bg: #0f172a;
    --rab-enterprise: #f59e0b;
  }

  .rab-ide-body {
    margin: 0;
    font-family: var(--rab-font-ui);
    background: var(--rab-bg);
    background-attachment: fixed;
    color: var(--rab-text);
    min-height: 100vh;
    overflow: hidden;
  }

  .rab-ide { display: flex; flex-direction: column; height: 100vh; }
  .rab-host-banner {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.35rem;
    padding: 0.55rem 1rem; background: #3b1d1d; color: #ffc9c9;
    border-bottom: 1px solid #7f1d1d; font-size: 0.8rem;
  }
  .rab-host-banner[hidden] { display: none !important; }
  .rab-host-banner strong { color: #fecaca; margin-right: 0.35rem; }

  .rab-topbar {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.5rem 1rem; background: var(--rab-surface);
    border-bottom: 1px solid var(--rab-border); flex-shrink: 0;
  }
  .rab-logo { font-weight: 700; color: var(--rab-brand); font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; }
  .rab-logo span { color: var(--rab-muted); font-weight: 400; font-size: 0.75rem; }
  .rab-branch { font-family: var(--rab-font-mono); font-size: 0.75rem; color: var(--rab-muted); background: var(--rab-elevated); padding: 0.25rem 0.6rem; border-radius: 4px; }
  .rab-spacer { flex: 1; }
  .rab-badge { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.2rem 0.5rem; border-radius: 4px; }
  .rab-badge-plan { background: var(--rab-brand); color: #fff; }
  .rab-badge-enterprise { background: var(--rab-enterprise); color: #000; }
  .rab-badge-github { background: var(--rab-github); color: #fff; }
  .rab-badge-isolate { background: color-mix(in srgb, var(--rab-green) 85%, #0b1220); color: #041016; }
  .rab-badge-direct { background: color-mix(in srgb, var(--rab-yellow) 80%, #111); color: #1c1400; }
  .rab-badge-role { background: var(--rab-elevated); color: var(--rab-purple); border: 1px solid var(--rab-border); }

  .rab-topbar select, .rab-topbar button {
    font-family: inherit; font-size: 0.75rem; background: var(--rab-elevated);
    color: var(--rab-text); border: 1px solid var(--rab-border); border-radius: 6px; padding: 0.35rem 0.6rem; cursor: pointer;
  }
  .rab-topbar a { color: var(--rab-muted); text-decoration: none; font-size: 0.75rem; margin-left: 0.75rem; }
  .rab-topbar a:hover { color: var(--rab-text); }

  .rab-workspace { display: flex; flex: 1; overflow: hidden; }

  .rab-activity {
    width: 48px; background: var(--rab-surface); border-right: 1px solid var(--rab-border);
    display: flex; flex-direction: column; align-items: center; padding: 0.5rem 0; gap: 0.25rem;
  }
  .rab-activity-btn {
    width: 36px; height: 36px; border: none; background: transparent; color: var(--rab-muted);
    border-radius: 6px; cursor: pointer; font-size: 1rem;
  }
  .rab-activity-btn.active, .rab-activity-btn:hover { background: var(--rab-elevated); color: var(--rab-text); }

  .rab-sidebar {
    width: 260px; background: var(--rab-panel); border-right: 1px solid var(--rab-border);
    display: flex; flex-direction: column; overflow: hidden; flex-shrink: 0;
  }
  .rab-sidebar-header {
    padding: 0.6rem 0.75rem; font-size: 0.65rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--rab-muted); border-bottom: 1px solid var(--rab-border);
  }
  .rab-sidebar-body { flex: 1; overflow-y: auto; padding: 0.5rem; font-size: 0.78rem; }

  .rab-tree-item {
    padding: 0.2rem 0.4rem; border-radius: 4px; cursor: pointer;
    font-family: var(--rab-font-mono); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .rab-tree-item:hover { background: var(--rab-elevated); }
  .rab-tree-item.active { background: var(--rab-accent); color: #fff; }
  .rab-tree-dir { color: var(--rab-blue); }
  .rab-tree-file { color: var(--rab-text); padding-left: 1rem; }

  .rab-center { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }

  .rab-tabs {
    display: flex; background: var(--rab-surface); border-bottom: 1px solid var(--rab-border);
    font-size: 0.75rem; overflow-x: auto;
  }
  .rab-tab {
    padding: 0.5rem 1rem; border: none; background: transparent; color: var(--rab-muted);
    cursor: pointer; border-bottom: 2px solid transparent; font-family: var(--rab-font-mono);
  }
  .rab-tab.active { color: var(--rab-text); border-bottom-color: var(--rab-accent); }

  .rab-editor {
    flex: 1; overflow: auto; background: var(--rab-editor-bg);
    font-family: var(--rab-font-mono); font-size: 0.8rem; line-height: 1.55; padding: 1rem;
    white-space: pre; tab-size: 2;
  }
  .rab-editor-empty { color: var(--rab-muted); font-family: var(--rab-font-ui); text-align: center; padding: 3rem; }

  .rab-agent-panel {
    height: 42%; min-height: 200px; border-top: 1px solid var(--rab-border);
    display: flex; flex-direction: column; background: var(--rab-surface);
  }
  .rab-agent-header {
    padding: 0.4rem 0.75rem; font-size: 0.65rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--rab-muted); border-bottom: 1px solid var(--rab-border);
    display: flex; justify-content: space-between;
  }
  .rab-stream { flex: 1; overflow-y: auto; padding: 0.75rem; font-size: 0.78rem; }
  .rab-empty-chat { color: var(--rab-muted); text-align: center; padding: 2rem 1rem; font-family: var(--rab-font-ui); }
  .rab-live-bar {
    display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap;
    padding: 0.4rem 0.75rem; font-size: 0.72rem; color: var(--rab-accent);
    background: linear-gradient(90deg, color-mix(in srgb, var(--rab-accent) 14%, transparent), transparent);
    border-bottom: 1px solid var(--rab-border);
  }
  .rab-live-bar[hidden] { display: none !important; }
  .rab-phase-rail { display: inline-flex; align-items: center; gap: 0.35rem; }
  .rab-phase-chip {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    padding: 0.15rem 0.45rem; border-radius: 999px; color: var(--rab-muted);
    background: var(--rab-elevated); border: 1px solid var(--rab-border);
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }
  .rab-phase-chip.active {
    color: #041016; background: var(--rab-accent); border-color: var(--rab-accent);
    transform: translateY(-1px);
  }
  .rab-phase-chip.done { color: var(--rab-green); border-color: color-mix(in srgb, var(--rab-green) 45%, transparent); }
  .rab-phase-sep { color: var(--rab-muted); font-size: 0.7rem; opacity: 0.7; }
  .rab-status-idle { color: var(--rab-muted); font-weight: 500; text-transform: none; letter-spacing: 0; }

  .rab-user-bubble { margin: 0 0 0.85rem; animation: rab-fade-in 180ms ease-out; }
  .rab-user-label { font-size: 0.65rem; font-weight: 700; color: var(--rab-muted); margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .rab-user-text {
    background: color-mix(in srgb, var(--rab-accent) 16%, var(--rab-elevated));
    border: 1px solid color-mix(in srgb, var(--rab-accent) 35%, var(--rab-border));
    border-radius: 12px; padding: 0.65rem 0.85rem; font-family: var(--rab-font-ui); line-height: 1.45;
  }

  .rab-turn {
    margin: 0 0 1rem; padding: 0.65rem 0.75rem 0.75rem;
    border: 1px solid var(--rab-border); border-radius: 12px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--rab-elevated) 80%, transparent), var(--rab-surface));
    animation: rab-fade-in 200ms ease-out;
  }
  .rab-turn-phases { display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.55rem; }
  .rab-turn-steps { display: flex; flex-direction: column; gap: 0.35rem; }
  .rab-step {
    display: flex; gap: 0.55rem; align-items: flex-start;
    padding: 0.35rem 0.45rem; border-radius: 8px;
    animation: rab-slide-in 160ms ease-out;
  }
  .rab-step-icon {
    width: 8px; height: 8px; margin-top: 0.4rem; border-radius: 50%; flex-shrink: 0;
    background: var(--rab-muted);
  }
  .rab-step-plan .rab-step-icon { background: var(--rab-blue); box-shadow: 0 0 0 3px color-mix(in srgb, var(--rab-blue) 22%, transparent); }
  .rab-step-tool .rab-step-icon { background: var(--rab-yellow); box-shadow: 0 0 0 3px color-mix(in srgb, var(--rab-yellow) 22%, transparent); }
  .rab-step-ok .rab-step-icon { background: var(--rab-green); }
  .rab-step-error .rab-step-icon { background: var(--rab-red); }
  .rab-step-title { font-family: var(--rab-font-ui); font-size: 0.8rem; color: var(--rab-text); }
  .rab-step-detail { font-family: var(--rab-font-mono); font-size: 0.7rem; color: var(--rab-muted); margin-top: 0.15rem; }
  .rab-turn-reply { margin-top: 0.65rem; padding-top: 0.55rem; border-top: 1px dashed var(--rab-border); }
  .rab-reply-stream, .rab-reply-block, .rab-reply-final {
    font-family: var(--rab-font-ui); font-size: 0.84rem; line-height: 1.5; white-space: pre-wrap;
  }
  .rab-token-delta { color: var(--rab-text); }
  .rab-applied { color: var(--rab-green); font-weight: 600; margin-top: 0.35rem; }

  .rab-event { margin-bottom: 0.6rem; animation: rab-fade-in 180ms ease-out; }
  .rab-event-tag { font-size: 0.6rem; padding: 0.1rem 0.4rem; border-radius: 3px; margin-right: 0.4rem; font-weight: 600; }
  .rab-tag-start, .rab-tag-status, .rab-tag-context, .rab-tag-session { background: color-mix(in srgb, var(--rab-blue) 25%, transparent); color: var(--rab-blue); }
  .rab-tag-tool { background: color-mix(in srgb, var(--rab-yellow) 25%, transparent); color: var(--rab-yellow); }
  .rab-tag-complete, .rab-tag-done { background: color-mix(in srgb, var(--rab-green) 25%, transparent); color: var(--rab-green); }
  .rab-tag-error { background: color-mix(in srgb, var(--rab-red) 25%, transparent); color: var(--rab-red); }
  .rab-tag-iteration, .rab-tag-delta { background: color-mix(in srgb, var(--rab-accent) 20%, transparent); color: var(--rab-accent); }
  .rab-event-body { background: var(--rab-elevated); border-radius: 8px; padding: 0.55rem 0.75rem; font-family: var(--rab-font-mono); border: 1px solid transparent; }
  .rab-event-user .rab-event-body { border-color: color-mix(in srgb, var(--rab-accent) 40%, transparent); }
  .rab-event-status .rab-event-body { font-family: var(--rab-font-ui); color: var(--rab-muted); }
  @keyframes rab-fade-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
  @keyframes rab-slide-in { from { opacity: 0; transform: translateX(-4px); } to { opacity: 1; transform: none; } }

  .rab-prompt-bar {
    display: flex; gap: 0.5rem; padding: 0.6rem; border-top: 1px solid var(--rab-border);
    background: var(--rab-input-bg); align-items: flex-end;
  }
  .rab-prompt-bar select { flex: 0 0 120px; }
  .rab-prompt-bar textarea {
    flex: 1; resize: none; min-height: 2.75rem; max-height: 8rem; background: var(--rab-elevated);
    border: 1px solid var(--rab-border); border-radius: 10px; color: var(--rab-text);
    font-family: inherit; font-size: 0.85rem; padding: 0.55rem 0.75rem; line-height: 1.4;
  }
  .rab-prompt-bar textarea:focus { outline: none; border-color: var(--rab-accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--rab-accent) 25%, transparent); }
  .rab-btn {
    padding: 0.5rem 1rem; border-radius: 8px; border: none; font-weight: 600;
    font-size: 0.8rem; cursor: pointer; font-family: inherit;
  }
  .rab-btn-primary { background: var(--rab-brand); color: #fff; }
  .rab-btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
  .rab-btn-accent { background: var(--rab-accent); color: #fff; }
  .rab-btn-github { background: var(--rab-github); color: #fff; }
  .rab-btn-secondary { background: var(--rab-elevated); color: var(--rab-text); border: 1px solid var(--rab-border); }

  .rab-right {
    width: 320px; background: var(--rab-panel); border-left: 1px solid var(--rab-border);
    display: flex; flex-direction: column; overflow: hidden; flex-shrink: 0;
  }
  .rab-right-tabs { display: flex; border-bottom: 1px solid var(--rab-border); }
  .rab-right-tab {
    flex: 1; padding: 0.5rem; border: none; background: transparent; color: var(--rab-muted);
    font-size: 0.7rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .rab-right-tab.active { color: var(--rab-text); border-bottom: 2px solid var(--rab-accent); }
  .rab-right-body { flex: 1; overflow-y: auto; padding: 0.75rem; font-size: 0.78rem; }

  .rab-change-item {
    padding: 0.5rem; border: 1px solid var(--rab-border); border-radius: 6px;
    margin-bottom: 0.5rem; cursor: pointer;
  }
  .rab-change-item:hover { border-color: var(--rab-accent); }
  .rab-change-path { font-family: var(--rab-font-mono); color: var(--rab-yellow); font-size: 0.72rem; }
  .rab-diff-view {
    font-family: var(--rab-font-mono); font-size: 0.68rem; line-height: 1.4;
    background: var(--rab-editor-bg); border-radius: 6px; padding: 0.5rem;
    max-height: 200px; overflow: auto; white-space: pre;
  }
  .rab-diff-add { color: var(--rab-green); }
  .rab-diff-del { color: var(--rab-red); }

  .rab-git-file { padding: 0.25rem 0; font-family: var(--rab-font-mono); font-size: 0.72rem; color: var(--rab-muted); }
  .rab-enterprise-item { padding: 0.4rem 0; border-bottom: 1px solid var(--rab-border); }
  .rab-locked { color: var(--rab-muted); font-size: 0.72rem; }
  .rab-feature-on { color: var(--rab-green); }
  .rab-feature-off { color: var(--rab-muted); opacity: 0.6; }

  .rab-pulse { display: inline-block; width: 6px; height: 6px; background: var(--rab-green); border-radius: 50%; animation: rab-pulse 1s infinite; margin-right: 0.4rem; }
  @keyframes rab-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .rab-badge-plan { border: none; cursor: pointer; font: inherit; }
  .rab-wizard-overlay, .rab-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.62); z-index: 50;
    display: flex; align-items: center; justify-content: center; padding: 1rem;
  }
  .rab-wizard-overlay[hidden], .rab-modal-overlay[hidden] { display: none !important; }
  .rab-wizard-card, .rab-modal-card {
    width: min(480px, 100%); background: var(--rab-surface); border: 1px solid var(--rab-border);
    border-radius: 12px; padding: 1.25rem 1.35rem; box-shadow: 0 16px 48px rgba(0,0,0,0.35);
  }
  .rab-wizard-card h2, .rab-modal-card h2 { margin: 0 0 0.35rem; font-size: 1.15rem; }
  .rab-wizard-sub { color: var(--rab-muted); font-size: 0.85rem; margin: 0 0 1rem; }
  .rab-wizard-doors { display: flex; gap: 0.4rem; margin-bottom: 1rem; }
  .rab-wizard-door {
    flex: 1; border: 1px solid var(--rab-border); background: var(--rab-elevated); color: var(--rab-muted);
    border-radius: 8px; padding: 0.45rem; cursor: pointer; font-size: 0.75rem; font-weight: 600;
  }
  .rab-wizard-door.active { border-color: var(--rab-accent); color: var(--rab-text); background: var(--rab-panel); }
  .rab-wizard-pane label { display: block; font-size: 0.72rem; color: var(--rab-muted); margin-bottom: 0.35rem; }
  .rab-wizard-pane input, .rab-wizard-pane select, .rab-wizard-pane textarea {
    width: 100%; box-sizing: border-box; margin-bottom: 0.65rem; background: var(--rab-input-bg);
    border: 1px solid var(--rab-border); border-radius: 8px; color: var(--rab-text);
    padding: 0.55rem 0.7rem; font-family: inherit; font-size: 0.85rem;
  }
  .rab-wizard-hint { color: var(--rab-muted); font-size: 0.72rem; margin: 0.25rem 0 0.75rem; }
  .rab-wizard-status { min-height: 1.2rem; font-size: 0.78rem; margin: 0.5rem 0; }
  .rab-wizard-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .rab-doctor-summary { margin-bottom: 0.75rem; font-size: 0.78rem; }
  .rab-doctor-item { padding: 0.45rem 0; border-bottom: 1px solid var(--rab-border); }
  .rab-doctor-msg { margin-top: 0.2rem; color: var(--rab-muted); font-size: 0.72rem; }
  .rab-upgrade-link {
    margin-left: 0.4rem; border: none; background: transparent; color: var(--rab-accent);
    cursor: pointer; font-size: 0.68rem; text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .rab-right { display: none; }
    .rab-sidebar { width: 200px; }
  }
  @media (max-width: 768px) {
    .rab-sidebar, .rab-activity { display: none; }
    .rab-agent-panel { height: 50%; }
  }
</style>
