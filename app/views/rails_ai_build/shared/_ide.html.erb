<script>
(function() {
  const root = document.getElementById('rab-ide');
  if (!root) return;

  const base = (root.dataset.base || '').replace(/\/+$/, '');
  const canStream = root.dataset.streaming === 'true';
  const canPr = root.dataset.pr === 'true';
  const canAudit = root.dataset.audit === 'true';
  const autoApply = root.dataset.autoApply === 'true';
  const needsWizard = root.dataset.needsWizard === 'true';
  const upgradeUrl = root.dataset.upgradeUrl || 'https://railsaibuild.com/pricing';
  let settingsToken = localStorage.getItem('rab-settings-token') || '';
  let pendingUpgradePlan = 'pro';

  async function ensureSettingsToken() {
    if (settingsToken) return settingsToken;
    try {
      const res = await fetch(base + '/settings/bootstrap', { method: 'POST' });
      const data = await res.json();
      if (data.settings_token) {
        settingsToken = data.settings_token;
        localStorage.setItem('rab-settings-token', settingsToken);
      }
    } catch (e) { /* open local settings allowed */ }
    return settingsToken;
  }

  function settingsHeaders(extra = {}) {
    const headers = Object.assign({ 'Content-Type': 'application/json' }, extra);
    if (settingsToken) headers['X-Rails-Ai-Build-Token'] = settingsToken;
    return headers;
  }

  async function apiFetch(path, options = {}) {
    const res = await fetch(base + path, options);
    let data = null;
    try { data = await res.json(); } catch (e) { data = {}; }
    if (res.status === 402 || data.code === 'plan_required') {
      openUpgradeModal(data);
    }
    return { res, data };
  }

  // Theme persistence (map legacy theme names)
  const themeSelect = document.getElementById('rab-theme');
  const themeAlias = { sand: 'forest', enterprise: 'slate' };
  let savedTheme = localStorage.getItem('rab-theme') || 'dark';
  if (themeAlias[savedTheme]) {
    savedTheme = themeAlias[savedTheme];
    localStorage.setItem('rab-theme', savedTheme);
  }
  document.documentElement.dataset.theme = savedTheme;
  if (themeSelect) themeSelect.value = savedTheme;
  themeSelect?.addEventListener('change', () => {
    document.documentElement.dataset.theme = themeSelect.value;
    localStorage.setItem('rab-theme', themeSelect.value);
  });

  // Activity panel switch (explorer / threads)
  document.querySelectorAll('.rab-activity-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.dataset.panel;
      document.querySelectorAll('.rab-activity-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('rab-sidebar-files').style.display = panel === 'files' ? 'flex' : 'none';
      document.getElementById('rab-sidebar-sessions').style.display = panel === 'sessions' ? 'flex' : 'none';
      if (panel === 'sessions') loadSessions();
      if (panel === 'agent') {
        document.querySelector('[data-tab="agent"]')?.click();
      }
    });
  });

  // Right panel tabs
  document.querySelectorAll('.rab-right-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.rab-right-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      ['tasks', 'changes', 'git', 'doctor', 'enterprise'].forEach(id => {
        const el = document.getElementById('rab-panel-' + id);
        if (el) el.style.display = tab.dataset.right === id ? 'block' : 'none';
      });
      if (tab.dataset.right === 'doctor') loadDoctor();
    });
  });

  // First-run wizard
  const wizard = document.getElementById('rab-wizard');
  function showWizard(show) {
    if (!wizard) return;
    wizard.hidden = !show;
  }
  if (needsWizard && !localStorage.getItem('rab-wizard-skipped')) showWizard(true);

  document.getElementById('rab-open-wizard')?.addEventListener('click', () => showWizard(true));
  document.getElementById('rab-wizard-close')?.addEventListener('click', () => showWizard(false));
  document.getElementById('rab-wizard-skip')?.addEventListener('click', async () => {
    localStorage.setItem('rab-wizard-skipped', '1');
    await ensureSettingsToken();
    await fetch(base + '/settings/wizard/complete', { method: 'POST', headers: settingsHeaders() });
    showWizard(false);
  });

  document.querySelectorAll('.rab-wizard-door').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.rab-wizard-door').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      ['byok', 'cloud', 'license'].forEach(id => {
        const pane = document.getElementById('rab-door-' + id);
        if (pane) pane.hidden = btn.dataset.door !== id;
      });
    });
  });

  function setWizardStatus(msg, ok) {
    const el = document.getElementById('rab-wizard-status');
    if (!el) return;
    el.textContent = msg || '';
    el.style.color = ok ? 'var(--rab-green)' : 'var(--rab-red)';
  }

  document.getElementById('rab-wizard-save-key')?.addEventListener('click', async () => {
    await ensureSettingsToken();
    const provider = document.getElementById('rab-wizard-provider').value;
    const key = document.getElementById('rab-wizard-key').value.trim();
    if (!key) return setWizardStatus('Paste an API key first');
    const body = { default_provider: provider }; body[provider] = key;
    const { res, data } = await apiFetch('/settings/keys', {
      method: 'POST', headers: settingsHeaders(), body: JSON.stringify(body)
    });
    if (!res.ok) return setWizardStatus(data.error || 'Failed to save key');
    await fetch(base + '/settings/wizard/complete', { method: 'POST', headers: settingsHeaders() });
    localStorage.setItem('rab-first-mission', '1');
    setWizardStatus('Key saved. Loading your first mission…', true);
    setTimeout(() => location.reload(), 700);
  });

  document.getElementById('rab-wizard-save-cloud')?.addEventListener('click', async () => {
    await ensureSettingsToken();
    const cloud = document.getElementById('rab-wizard-cloud').value.trim();
    if (!cloud) return setWizardStatus('Paste a cloud API key first');
    const { res, data } = await apiFetch('/settings/keys', {
      method: 'POST', headers: settingsHeaders(),
      body: JSON.stringify({ cloud_api_key: cloud, default_provider: 'cloud' })
    });
    if (!res.ok) {
      if (data.code === 'plan_required') {
        setWizardStatus('Cloud key saved needs Pro+ hosted models — upgrade or use BYOK.');
        openUpgradeModal(data);
        return;
      }
      return setWizardStatus(data.error || 'Failed to save cloud key');
    }
    await fetch(base + '/settings/wizard/complete', { method: 'POST', headers: settingsHeaders() });
    localStorage.setItem('rab-first-mission', '1');
    setWizardStatus('Cloud key saved. Loading your first mission…', true);
    setTimeout(() => location.reload(), 700);
  });

  document.getElementById('rab-wizard-save-license')?.addEventListener('click', async () => {
    await ensureSettingsToken();
    const license = document.getElementById('rab-wizard-license').value.trim();
    if (!license) return setWizardStatus('Paste a license token first');
    const { res, data } = await apiFetch('/settings/license', {
      method: 'POST', headers: settingsHeaders(), body: JSON.stringify({ license_key: license })
    });
    if (!res.ok) return setWizardStatus(data.error || 'Invalid license');
    await fetch(base + '/settings/wizard/complete', { method: 'POST', headers: settingsHeaders() });
    localStorage.setItem('rab-first-mission', '1');
    setWizardStatus('License activated (' + (data.plan || data.activation?.plan || '') + '). Loading mission…', true);
    setTimeout(() => location.reload(), 700);
  });

  // Upgrade modal
  const upgradeModal = document.getElementById('rab-upgrade-modal');
  function openUpgradeModal(payload = {}) {
    if (!upgradeModal) return;
    pendingUpgradePlan = payload.suggested_plan || payload.checkout?.plan || 'pro';
    const msg = document.getElementById('rab-upgrade-message');
    const planEl = document.getElementById('rab-upgrade-plan');
    if (msg) msg.textContent = payload.error || 'This feature requires a higher plan.';
    if (planEl) planEl.textContent = String(pendingUpgradePlan).toUpperCase();
    upgradeModal.hidden = false;
  }
  function closeUpgradeModal() { if (upgradeModal) upgradeModal.hidden = true; }
  document.getElementById('rab-upgrade-close')?.addEventListener('click', closeUpgradeModal);
  document.getElementById('rab-plan-badge')?.addEventListener('click', () => openUpgradeModal({
    error: 'Upgrade to unlock diff preview, hosted models, git, PRs, and team features.',
    suggested_plan: root.dataset.plan === 'free' ? 'pro' : 'team'
  }));
  document.getElementById('rab-open-upgrade')?.addEventListener('click', () => openUpgradeModal({
    error: 'Choose a plan to unlock more of the Cursor-class loop.',
    suggested_plan: 'pro'
  }));
  document.querySelectorAll('.rab-upgrade-link').forEach(btn => {
    btn.addEventListener('click', () => openUpgradeModal({
      error: 'Feature :' + btn.dataset.feature + ' is locked on your current plan.',
      suggested_plan: 'pro'
    }));
  });
  document.getElementById('rab-upgrade-checkout')?.addEventListener('click', async () => {
    const status = document.getElementById('rab-upgrade-status');
    const { res, data } = await apiFetch('/billing/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        plan: pendingUpgradePlan,
        success_url: window.location.href + (window.location.href.includes('?') ? '&' : '?') + 'upgraded=true',
        cancel_url: window.location.href
      })
    });
    if (data.checkout_url) {
      window.location.href = data.checkout_url;
      return;
    }
    if (status) {
      status.textContent = data.error || 'Stripe not configured — open pricing or activate a license in the wizard.';
      status.style.color = 'var(--rab-yellow)';
    }
    if (!res.ok) window.open(upgradeUrl, '_blank');
  });

  document.getElementById('rab-upgrade-portal')?.addEventListener('click', async () => {
    const status = document.getElementById('rab-upgrade-status');
    const { res, data } = await apiFetch('/billing/portal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ return_url: window.location.href })
    });
    if (data.portal_url) {
      window.location.href = data.portal_url;
      return;
    }
    if (status) {
      status.textContent = data.error || data.hint || 'Billing portal unavailable — complete checkout first.';
      status.style.color = 'var(--rab-yellow)';
    }
  });

  // Doctor panel
  async function loadDoctor() {
    const summary = document.getElementById('rab-doctor-summary');
    const list = document.getElementById('rab-doctor-list');
    if (!summary || !list) return;
    summary.textContent = 'Running diagnostics…';
    try {
      const res = await fetch(base + '/support/doctor');
      const data = await res.json();
      const healthy = data.status === 'healthy';
      summary.innerHTML = '<span class="' + (healthy ? 'rab-feature-on' : 'rab-feature-off') + '">' +
        (healthy ? '✓ Healthy' : '○ Issues found') + '</span> · ' + (data.plan || '') + ' · v' + (data.version || '');
      list.innerHTML = (data.checks || []).map(c => {
        const icon = c.status === 'ok' ? '✓' : (c.status === 'warn' ? '!' : '✗');
        const cls = c.status === 'ok' ? 'rab-feature-on' : 'rab-feature-off';
        return '<div class="rab-doctor-item"><span class="' + cls + '">' + icon + '</span> <strong>' +
          escapeHtml(c.name) + '</strong><div class="rab-doctor-msg">' + escapeHtml(c.message || '') +
          (c.fix ? '<div class="rab-wizard-hint">Fix: ' + escapeHtml(c.fix) + '</div>' : '') +
          '</div></div>';
      }).join('');
    } catch (e) {
      summary.textContent = e.message;
    }
  }
  document.getElementById('rab-refresh-doctor')?.addEventListener('click', loadDoctor);

  // Editor tabs
  document.querySelectorAll('.rab-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.rab-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const editor = document.getElementById('rab-editor');
      const agent = document.getElementById('rab-agent-panel');
      if (tab.dataset.tab === 'agent') {
        editor.style.display = 'none';
        agent.style.height = '100%';
      } else {
        editor.style.display = 'block';
        agent.style.height = '42%';
      }
    });
  });

  // File tree
  async function loadTree() {
    const treeEl = document.getElementById('rab-file-tree');
    try {
      const res = await fetch(base + '/workspace/tree?depth=3');
      const data = await res.json();
      if (data.error) { treeEl.innerHTML = '<p class="rab-locked">' + data.error + '</p>'; return; }
      treeEl.innerHTML = renderTree(data.entries || []);
    } catch (e) {
      treeEl.innerHTML = '<p class="rab-locked">' + e.message + '</p>';
    }
  }

  function renderTree(entries, indent = 0) {
    return entries.map(e => {
      if (e.type === 'directory') {
        const kids = e.children?.length ? renderTree(e.children, indent + 1) : '';
        return '<div class="rab-tree-item rab-tree-dir" style="padding-left:' + (indent * 12) + 'px">📁 ' + e.name + '</div>' + kids;
      }
      return '<div class="rab-tree-item rab-tree-file" data-path="' + e.path + '" style="padding-left:' + (indent * 12 + 12) + 'px">📄 ' + e.name + '</div>';
    }).join('');
  }

  document.getElementById('rab-file-tree')?.addEventListener('click', async (ev) => {
    const item = ev.target.closest('[data-path]');
    if (!item) return;
    document.querySelectorAll('.rab-tree-item').forEach(i => i.classList.remove('active'));
    item.classList.add('active');
    const res = await fetch(base + '/workspace/file?path=' + encodeURIComponent(item.dataset.path));
    const data = await res.json();
    const editor = document.getElementById('rab-editor');
    if (data.content) {
      editor.textContent = data.content;
    } else {
      editor.innerHTML = '<div class="rab-editor-empty">' + (data.error || 'Cannot read file') + '</div>';
    }
  });

  loadTree();

  // SSE streaming + live feedback
  const streamEl = document.getElementById('rab-stream');
  const runBtn = document.getElementById('rab-run-btn');
  const statusEl = document.getElementById('rab-agent-status');
  const liveBar = document.getElementById('rab-live-bar');
  const liveText = document.getElementById('rab-live-text');
  const promptEl = document.getElementById('rab-prompt');
  let running = false;
  let awaitingPlan = false;
  let sessionId = localStorage.getItem('rab-session-id') || null;
  let historyGen = 0;
  let sessionsRefreshTimer = null;
  const modeSel = document.getElementById('rab-mode');
  (function restoreMode() {
    if (!modeSel) return;
    const saved = localStorage.getItem('rab-mode');
    if (saved && [...modeSel.options].some((o) => o.value === saved)) modeSel.value = saved;
    else modeSel.value = 'stream';
    modeSel.addEventListener('change', () => localStorage.setItem('rab-mode', modeSel.value));
  })();

  // Guided first mission after activation
  if (localStorage.getItem('rab-first-mission') === '1') {
    localStorage.removeItem('rab-first-mission');
    if (promptEl && !promptEl.value.trim()) {
      promptEl.value = 'Add a GET /health endpoint that returns JSON { status: "ok" }';
      promptEl.focus();
      if (statusEl) {
        statusEl.className = 'rab-status-idle';
        statusEl.textContent = 'First mission ready — press Enter (or Send) to run';
      }
      streamEl?.insertAdjacentHTML('beforeend',
        '<div class="rab-event"><span class="rab-event-tag rab-tag-start">mission</span>' +
        '<div class="rab-event-body">Welcome! Run the prefilled prompt to ship your first change.</div></div>');
    }
  }

  let currentTurn = null;
  let replyBufferEl = null;
  let lastStepKey = '';
  let turnFiles = [];
  const phaseOrder = { planning: 0, executing: 1, reply: 2, done: 3 };
  const QUIET_STATUS = new Set(['prepare', 'heal', 'ready', 'prevent', 'start', 'route', 'context']);

  function setLive(message, phase) {
    if (!liveBar || !liveText) return;
    if (message) {
      liveBar.hidden = false;
      liveText.textContent = message;
      if (statusEl) statusEl.textContent = message;
      if (phase) setGlobalPhase(phase);
    } else {
      liveBar.hidden = true;
      setGlobalPhase(null);
      if (statusEl) {
        statusEl.className = 'rab-status-idle';
        statusEl.textContent = 'Ready — Enter to send, Shift+Enter for newline';
      }
    }
  }

  function setGlobalPhase(phase) {
    document.querySelectorAll('#rab-phase-rail .rab-phase-chip').forEach((chip) => {
      const p = chip.dataset.phase;
      chip.classList.toggle('active', !!phase && p === phase);
      chip.classList.toggle('done', !!phase && phaseOrder[p] < phaseOrder[phase]);
    });
  }

  function escapeHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function ensureTurn() {
    if (currentTurn?.el?.isConnected) return currentTurn;
    const el = document.createElement('div');
    el.className = 'rab-turn';
    el.innerHTML =
      '<div class="rab-turn-phases">' +
        '<span class="rab-phase-chip" data-phase="planning">Planning</span>' +
        '<span class="rab-phase-sep">→</span>' +
        '<span class="rab-phase-chip" data-phase="executing">Executing</span>' +
        '<span class="rab-phase-sep">→</span>' +
        '<span class="rab-phase-chip" data-phase="reply">Reply</span>' +
      '</div>' +
      '<div class="rab-turn-steps"></div>' +
      '<div class="rab-turn-reply" hidden></div>';
    streamEl.appendChild(el);
    currentTurn = {
      el,
      steps: el.querySelector('.rab-turn-steps'),
      reply: el.querySelector('.rab-turn-reply'),
      chips: el.querySelectorAll('.rab-phase-chip'),
      phase: 'planning'
    };
    replyBufferEl = null;
    return currentTurn;
  }

  function setTurnPhase(phase) {
    const turn = ensureTurn();
    turn.phase = phase;
    turn.chips.forEach((chip) => {
      const p = chip.dataset.phase;
      chip.classList.toggle('active', p === phase);
      chip.classList.toggle('done', phaseOrder[p] < phaseOrder[phase]);
    });
    setGlobalPhase(phase === 'done' ? 'reply' : phase);
  }

  function addStep(kind, title, detailHtml) {
    const key = kind + '|' + title;
    if (key === lastStepKey) return null;
    lastStepKey = key;
    const turn = ensureTurn();
    const step = document.createElement('div');
    step.className = 'rab-step rab-step-' + kind;
    step.innerHTML =
      '<span class="rab-step-icon" aria-hidden="true"></span>' +
      '<div class="rab-step-body">' +
        '<div class="rab-step-title">' + escapeHtml(title) + '</div>' +
        (detailHtml ? '<div class="rab-step-detail">' + detailHtml + '</div>' : '') +
      '</div>';
    turn.steps.appendChild(step);
    streamEl.scrollTop = streamEl.scrollHeight;
    return step;
  }

  function showPlanCard(prompt, mode, skill, onApprove) {
    const empty = streamEl.querySelector('.rab-empty-chat');
    if (empty) empty.remove();
    awaitingPlan = true;
    setLive('Review the plan, then Run plan or Cancel', 'planning');
    const card = document.createElement('div');
    card.className = 'rab-plan-card';
    card.innerHTML =
      '<div class="rab-plan-title">Plan — approve before changes</div>' +
      '<div class="rab-plan-body">' +
        '<p><strong>Request:</strong> ' + escapeHtml(prompt) + '</p>' +
        '<ul>' +
          '<li>Mode: ' + escapeHtml(modeLabel(mode)) + (skill ? ' · skill ' + escapeHtml(skill) : '') + '</li>' +
          '<li>Explore the app, then make focused edits</li>' +
          '<li>List every file that changed when done (Changes → This run)</li>' +
        '</ul>' +
        '<p class="rab-plan-ask">Does this look right? Approve to execute, or Cancel to edit your prompt.</p>' +
      '</div>' +
      '<div class="rab-plan-actions">' +
        '<button type="button" class="rab-btn rab-btn-primary" data-rab-approve>Run plan</button>' +
        '<button type="button" class="rab-btn rab-btn-secondary" data-rab-cancel>Cancel</button>' +
      '</div>';
    streamEl.appendChild(card);
    streamEl.scrollTop = streamEl.scrollHeight;
    card.querySelector('[data-rab-approve]')?.addEventListener('click', () => {
      awaitingPlan = false;
      card.remove();
      onApprove();
    });
    card.querySelector('[data-rab-cancel]')?.addEventListener('click', () => {
      awaitingPlan = false;
      card.remove();
      setLive(null);
      if (promptEl && !promptEl.value.trim()) promptEl.value = prompt;
      promptEl?.focus();
    });
  }

  function modeLabel(mode) {
    return ({ stream: 'Agent', composer: 'Plan first', build: 'Build', queue: 'Background queue' })[mode] || mode;
  }

  function renderAppliedFiles(files) {
    const list = document.getElementById('rab-applied-list');
    if (!list) return;
    const items = (files || []).filter(Boolean);
    if (!items.length) {
      list.innerHTML = '<p class="rab-locked" id="rab-applied-empty">Nothing changed yet — run the agent to see files here.</p>';
      return;
    }
    list.innerHTML = items.map((f) => {
      const path = f.path || f;
      const status = f.status || 'changed';
      return '<div class="rab-change-item rab-applied-item" data-path="' + escapeHtml(path) + '">' +
        '<div class="rab-change-path">' + escapeHtml(path) + '</div>' +
        '<div style="font-size:0.68rem;color:var(--rab-muted)">' + escapeHtml(status) + '</div></div>';
    }).join('');
    document.querySelector('[data-right="changes"]')?.click();
    list.querySelectorAll('[data-path]').forEach((el) => {
      el.addEventListener('click', () => {
        const path = el.dataset.path;
        const treeItem = document.querySelector('.rab-tree-file[data-path="' + CSS.escape(path) + '"]');
        treeItem?.click();
      });
    });
  }

  function showDoneSummary(data) {
    const files = data.applied_files || turnFiles || [];
    const paths = files.map((f) => f.path || f).filter(Boolean);
    const turn = ensureTurn();
    setTurnPhase('done');
    turn.reply.hidden = false;
    let html = '<div class="rab-done-summary">';
    html += '<div class="rab-done-title">Done</div>';
    if (data.content) html += '<div class="rab-reply-final">' + escapeHtml(String(data.content).slice(0, 2000)) + '</div>';
    if (paths.length) {
      html += '<div class="rab-done-files"><strong>Changed files</strong><ul>' +
        paths.map((p) => '<li>' + escapeHtml(p) + '</li>').join('') + '</ul></div>';
    } else {
      html += '<div class="rab-done-files rab-muted">No file writes in this run.</div>';
    }
    if (data.compare_url || data.pr_url) {
      html += ' <a href="' + (data.compare_url || data.pr_url) + '" target="_blank">Open PR</a>';
    }
    html += '</div>';
    turn.reply.insertAdjacentHTML('beforeend', html);
    renderAppliedFiles(files);
    if (data.pending_changes?.length) refreshChanges(data.pending_changes);
    if (paths.length) loadTree();
    streamEl.scrollTop = streamEl.scrollHeight;
  }

  function humanGeneratorPlan(data) {
    const mode = data.mode || 'ai';
    if (mode === 'generator' && data.generator) {
      return 'Using Rails generator · ' + data.generator +
        (data.args?.length ? ' ' + data.args.join(' ') : '');
    }
    if (mode === 'hybrid' && data.generator) {
      return 'Plan · AI + generator ' + data.generator;
    }
    return data.reason || 'Plan · explore with tools, then edit files';
  }

  function toolArgsSummary(name, args) {
    if (!args || typeof args !== 'object') return '';
    const path = args.path || args.file;
    const q = args.query || args.pattern;
    if (path) return escapeHtml(String(path));
    if (q) return escapeHtml(String(q)).slice(0, 80);
    const keys = Object.keys(args);
    if (!keys.length) return '';
    return escapeHtml(JSON.stringify(args)).slice(0, 120);
  }

  function appendUserBubble(content) {
    const empty = streamEl.querySelector('.rab-empty-chat');
    if (empty) empty.remove();
    currentTurn = null;
    replyBufferEl = null;
    const bubble = document.createElement('div');
    bubble.className = 'rab-user-bubble';
    bubble.innerHTML = '<div class="rab-user-label">You</div><div class="rab-user-text">' +
      escapeHtml(content) + '</div>';
    streamEl.appendChild(bubble);
    streamEl.scrollTop = streamEl.scrollHeight;
  }

  function appendReplyToken(text) {
    const turn = ensureTurn();
    setTurnPhase('reply');
    turn.reply.hidden = false;
    if (!replyBufferEl) {
      replyBufferEl = document.createElement('div');
      replyBufferEl.className = 'rab-reply-stream';
      turn.reply.appendChild(replyBufferEl);
    }
    replyBufferEl.insertAdjacentHTML('beforeend', '<span class="rab-token-delta">' + escapeHtml(text) + '</span>');
    streamEl.scrollTop = streamEl.scrollHeight;
  }

  function formatEvent(event, data) {
    // Legacy HTML helper for task watcher / session list clicks
    if (event === 'session') {
      return '<div class="rab-event"><span class="rab-event-tag rab-tag-session">session</span>' +
        '<div class="rab-event-body">Thread ' + escapeHtml(String(data.id || '').slice(0, 8)) + '…</div></div>';
    }
    return '<div class="rab-event"><span class="rab-event-tag">' + escapeHtml(event) +
      '</span><div class="rab-event-body">' +
      escapeHtml(typeof data === 'string' ? data : JSON.stringify(data)) + '</div></div>';
  }

  function scheduleLoadSessions() {
    if (sessionsRefreshTimer) clearTimeout(sessionsRefreshTimer);
    sessionsRefreshTimer = setTimeout(() => { loadSessions(); }, 250);
  }

  function bindSession(id, { quiet } = {}) {
    if (!id) return;
    const changed = sessionId !== id;
    sessionId = id;
    localStorage.setItem('rab-session-id', sessionId);
    if (!quiet && changed) {
      setTurnPhase('planning');
      addStep('plan', 'Thread ' + String(sessionId).slice(0, 8) + '…');
    }
    scheduleLoadSessions();
  }

  async function ensureSession() {
    if (sessionId) {
      // Verify it still exists; otherwise create a fresh one
      try {
        const res = await fetch(base + '/ai/sessions/' + encodeURIComponent(sessionId));
        if (res.ok) return sessionId;
      } catch (e) { /* create below */ }
      sessionId = null;
      localStorage.removeItem('rab-session-id');
    }
    const res = await fetch(base + '/ai/sessions', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}'
    });
    const data = await res.json();
    bindSession(data.id, { quiet: true });
    return sessionId;
  }

  function appendEvent(event, data, opts) {
    opts = opts || {};
    // Background task watchers must not steal the active chat / rewrite the stream
    if (opts.fromTask && (event === 'session' || event === 'user')) return;
    if (opts.fromTask && !opts.followInAgent) {
      if (event === 'complete' || event === 'done' || event === 'finished' || event === 'error') {
        loadTasks();
      }
      return;
    }

    const empty = streamEl.querySelector('.rab-empty-chat');
    if (empty) empty.remove();

    if (event === 'user') {
      appendUserBubble(data.content || '');
      return;
    }

    if (event === 'status' && data.phase === 'isolate') {
      setTurnPhase('planning');
      const title = data.message || (data.shadow ? 'Isolated worktree ready' : 'Direct host writes');
      setLive(title, 'planning');
      addStep('plan', title, data.branch ? escapeHtml('branch ' + data.branch) : '');
      return;
    }

    if (event === 'status') {
      const phase = data.phase || '';
      const msg = data.message || 'Working…';
      // Never dump checks/JSON — keep the timeline short like Cursor
      if (QUIET_STATUS.has(phase)) {
        setTurnPhase('planning');
        setLive(msg, 'planning');
        if (phase === 'ready' || phase === 'prepare') addStep('plan', msg.split(';')[0]);
        return;
      }
      setTurnPhase(phase === 'tool' || phase === 'reply' ? phase === 'reply' ? 'reply' : 'executing' : 'planning');
      setLive(msg, phase === 'reply' ? 'reply' : (phase === 'tool' ? 'executing' : 'planning'));
      addStep(phase === 'tool' ? 'tool' : 'plan', msg);
      return;
    }

    if (event === 'start') {
      setTurnPhase('planning');
      const title = 'Starting: ' + (data.task || data.message || 'request');
      setLive(title, 'planning');
      addStep('plan', title);
      return;
    }

    if (event === 'attempt') {
      setTurnPhase('planning');
      addStep('plan', 'Attempt ' + (data.number || 1) + '/' + (data.max || '?'));
      return;
    }

    if (event === 'queued') {
      setTurnPhase('planning');
      addStep('plan', 'Queued background task', data.branch ? escapeHtml(data.branch) : '');
      return;
    }

    if (event === 'running') {
      setTurnPhase('executing');
      setLive('Running background task…', 'executing');
      addStep('tool', 'Task running', data.branch ? escapeHtml(data.branch) : '');
      return;
    }

    if (event === 'snapshot') {
      return; // ignore raw task snapshots
    }

    if (event === 'generator_plan') {
      setTurnPhase('planning');
      const title = humanGeneratorPlan(data);
      setLive(title, 'planning');
      addStep('plan', title);
      return;
    }

    if (event === 'generator_result') {
      setTurnPhase('executing');
      const ok = data.ok !== false && data.status !== 'failed';
      setLive(ok ? 'Generator finished' : 'Generator failed', 'executing');
      addStep(ok ? 'ok' : 'error', ok ? 'Generator finished' : 'Generator failed',
        data.message || data.error ? escapeHtml(String(data.message || data.error)) : '');
      return;
    }

    if (event === 'session') {
      // Only bind when this event belongs to the chat the user is running
      if (opts.fromTask && !opts.followInAgent) return;
      if (data.id && (!sessionId || data.id === sessionId || running)) {
        bindSession(data.id, { quiet: sessionId === data.id });
      }
      return;
    }

    if (event === 'context') {
      setTurnPhase('planning');
      setLive('Context loaded', 'planning');
      addStep('plan', 'Context loaded · Rails ' + (data.rails || data.rails_version || '?'));
      return;
    }

    if (event === 'tool_call') {
      setTurnPhase('executing');
      const detail = toolArgsSummary(data.name, data.arguments);
      setLive('Running ' + (data.name || 'tool') + '…', 'executing');
      addStep('tool', data.name || 'tool', detail);
      const path = data.arguments && (data.arguments.path || data.arguments.file);
      if (data.name === 'write_file' && path) turnFiles.push({ path: path, status: 'writing' });
      return;
    }

    if (event === 'tool_result') {
      setTurnPhase('executing');
      const summary = data.summary || ('Finished ' + (data.name || 'tool'));
      setLive(summary, 'executing');
      addStep(/error|fail/i.test(summary) ? 'error' : 'ok', summary);
      if (/applied|written|generated/i.test(summary)) {
        loadTree();
        const m = summary.match(/(?:Applied|Queued|Writing|Finished)\s+(\S+)/i);
        // keep turnFiles; render on done
      }
      return;
    }

    if (event === 'verify') {
      setTurnPhase('executing');
      addStep(data.passed ? 'ok' : 'error', data.passed ? 'Verification passed' : 'Verification failed');
      return;
    }

    if (event === 'delta' || event === 'iteration') {
      if (data.token || event === 'delta') {
        setLive('Streaming reply…', 'reply');
        appendReplyToken(data.content || '');
        return;
      }
      if (data.content) {
        setTurnPhase('reply');
        ensureTurn().reply.hidden = false;
        ensureTurn().reply.insertAdjacentHTML('beforeend',
          '<div class="rab-reply-block">' + escapeHtml(data.content) + '</div>');
      }
      return;
    }

    if (event === 'host_safety') {
      applyHostSafety(data);
      setTurnPhase('executing');
      addStep(data.healthy ? 'ok' : 'error',
        data.healthy ? ('Host Safety OK' + (data.promoted ? ' · shadow promoted' : '')) :
          ('Host unhealthy' + (data.rolled_back ? ' · rolled back' : '')));
      return;
    }

    if (event === 'complete' || event === 'done' || event === 'finished' || event === 'pr_ready') {
      if (opts.fromTask && !opts.followInAgent) {
        loadTasks();
        return;
      }
      const sid = data.session_id || data.session?.id;
      if (sid && (!sessionId || sid === sessionId || running)) bindSession(sid, { quiet: true });
      if (data.host_safety) applyHostSafety(data.host_safety);
      if (data.applied_files?.length) turnFiles = data.applied_files;
      showDoneSummary(data);
      setLive('Done — review Changes → This run', 'reply');
      scheduleLoadSessions();
      return;
    }

    if (event === 'error') {
      setTurnPhase('done');
      setLive(data.error || 'Error', 'reply');
      addStep('error', data.error || 'Unknown error');
      return;
    }

    // Unknown events → one short line, NEVER raw JSON dumps
    const short = data?.message || data?.description || data?.reason || data?.status || '';
    if (!short && (event === 'delta' || !event)) return;
    setTurnPhase(currentTurn?.phase || 'planning');
    addStep('plan', event, escapeHtml(String(short)).slice(0, 160));
  }

  async function consumeSse(res, onChunk) {
    if (!res.ok) throw new Error('Request failed (' + res.status + ')');
    if (!res.body) throw new Error('No response stream');
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const parts = buffer.split('\n\n');
      buffer = parts.pop();
      for (const part of parts) {
        const em = part.match(/event: (\w+)/);
        const dm = part.match(/data: (.+)/s);
        if (em && dm) onChunk(em[1], JSON.parse(dm[1]));
      }
    }
  }

  async function executeAgent(prompt, mode) {
    if (running) return;
    const skill = document.getElementById('rab-skill')?.value || undefined;
    turnFiles = [];
    lastStepKey = '';
    currentTurn = null;
    replyBufferEl = null;

    try {
      await ensureSession();
    } catch (e) {
      appendEvent('error', { error: 'Could not open chat thread: ' + e.message });
      return;
    }

    if (mode === 'queue') {
      setLive('Queueing task…', 'planning');
      try {
        const res = await fetch(base + '/tasks', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ task: prompt, skill: skill, verify: true, session_id: sessionId })
        });
        const data = await res.json();
        if (data.error) {
          appendEvent('error', { error: data.error });
          return;
        }
        appendEvent('queued', { description: data.description || prompt, branch: data.branch, id: data.id });
        setLive('Background task running…', 'executing');
        watchTask(data.id, { followInAgent: true });
        loadTasks();
      } catch (err) {
        appendEvent('error', { error: err.message });
      }
      return;
    }

    running = true;
    if (runBtn) {
      runBtn.disabled = true;
      runBtn.textContent = 'Working…';
    }
    setLive(mode === 'composer' ? 'Executing plan…' : (mode === 'build' ? 'Building…' : 'Planning…'), 'planning');
    ensureTurn();
    setTurnPhase('planning');

    try {
      if (mode === 'build' || mode === 'composer') {
        const res = await fetch(base + '/build/stream', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'text/event-stream' },
          body: JSON.stringify({
            task: prompt,
            skill: skill,
            verify: true,
            composer: mode === 'composer',
            session_id: sessionId
          })
        });
        await consumeSse(res, (event, data) => appendEvent(event, data));
        loadTasks();
        return;
      }

      if (!canStream) {
        appendEvent('status', { message: 'Streaming unavailable — using sync chat…' });
        const res = await fetch(base + '/ai/chat', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: prompt,
            skill: skill,
            session_id: sessionId,
            provider: document.getElementById('rab-provider')?.value
          })
        });
        const data = await res.json();
        if (data.error) appendEvent('error', { error: data.error });
        else {
          if (data.session?.id) bindSession(data.session.id, { quiet: true });
          appendEvent('done', data);
        }
        return;
      }

      const res = await fetch(base + '/ai/stream', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'text/event-stream' },
        body: JSON.stringify({
          message: prompt,
          skill: skill,
          provider: document.getElementById('rab-provider')?.value,
          session_id: sessionId
        })
      });
      await consumeSse(res, (event, data) => appendEvent(event, data));
    } catch (err) {
      appendEvent('error', { error: err.message });
    } finally {
      running = false;
      if (runBtn) {
        runBtn.disabled = false;
        runBtn.textContent = 'Send';
      }
      setLive(null);
      promptEl?.focus();
    }
  }

  async function runAgent(e) {
    e?.preventDefault?.();
    e?.stopPropagation?.();
    if (running || awaitingPlan) return;
    const prompt = promptEl?.value.trim();
    if (!prompt) {
      promptEl?.focus();
      return;
    }
    const mode = modeSel?.value || 'stream';
    localStorage.setItem('rab-mode', mode);
    const skill = document.getElementById('rab-skill')?.value || '';

    appendEvent('user', { content: prompt });
    if (promptEl) {
      promptEl.value = '';
      promptEl.style.height = 'auto';
    }

    // Cursor-style: ask before writing (Agent / Plan first / Build)
    if (mode === 'stream' || mode === 'composer' || mode === 'build') {
      showPlanCard(prompt, mode, skill, () => { executeAgent(prompt, mode); });
      return;
    }

    await executeAgent(prompt, mode);
  }

  const promptForm = document.getElementById('rab-prompt-form');
  promptForm?.addEventListener('submit', runAgent);

  function isSendHotkey(ev) {
    if (ev.shiftKey || ev.altKey || ev.ctrlKey || ev.metaKey || ev.isComposing) return false;
    return ev.key === 'Enter' || ev.code === 'Enter' || ev.keyCode === 13;
  }

  // Enter to send (Shift+Enter = newline). Capture phase so Enter is not swallowed.
  promptEl?.addEventListener('keydown', (ev) => {
    if (!isSendHotkey(ev)) return;
    ev.preventDefault();
    ev.stopPropagation();
    if (running || awaitingPlan) return;
    if (promptForm?.requestSubmit) promptForm.requestSubmit();
    else runAgent(ev);
  }, true);

  // Auto-grow textarea
  promptEl?.addEventListener('input', () => {
    promptEl.style.height = 'auto';
    promptEl.style.height = Math.min(promptEl.scrollHeight, 128) + 'px';
  });

  // Changes — pending review diffs (separate from This run applied files)
  function refreshChanges(changes) {
    const list = document.getElementById('rab-pending-list');
    if (!list || !changes) return;
    const items = (Array.isArray(changes) ? changes : []).filter((c) => c && (c.path || c.id));
    if (!items.length) return;
    list.innerHTML = items.map((c) => {
      const path = c.path || 'unknown';
      const id = c.id || '';
      return '<div class="rab-change-item"' + (id ? ' data-change-id="' + escapeHtml(String(id)) + '"' : '') + '>' +
        '<div class="rab-change-path">' + escapeHtml(path) + '</div>' +
        (id ? '<div style="margin-top:0.4rem;display:flex;gap:0.4rem">' +
          '<button class="rab-btn rab-btn-secondary rab-apply-btn" data-id="' + escapeHtml(String(id)) + '" style="padding:0.25rem 0.5rem;font-size:0.7rem">Apply</button>' +
          '<button class="rab-btn rab-btn-secondary rab-reject-btn" data-id="' + escapeHtml(String(id)) + '" style="padding:0.25rem 0.5rem;font-size:0.7rem">Reject</button>' +
        '</div>' : '') +
      '</div>';
    }).join('');
    document.querySelector('[data-right="changes"]')?.click();
  }

  document.querySelectorAll('.rab-apply-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      await fetch(base + '/changes/' + btn.dataset.id + '/apply', { method: 'POST' });
      location.reload();
    });
  });
  document.querySelectorAll('.rab-reject-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      await fetch(base + '/changes/' + btn.dataset.id + '/reject', { method: 'POST' });
      location.reload();
    });
  });
  document.getElementById('rab-apply-all')?.addEventListener('click', async () => {
    await fetch(base + '/changes/apply_all', { method: 'POST' });
    location.reload();
  });
  function applyHostSafety(data) {
    const banner = document.getElementById('rab-host-banner');
    const msg = document.getElementById('rab-host-banner-msg');
    if (!banner || !data) return;
    if (data.healthy && !data.rolled_back) {
      banner.hidden = true;
      return;
    }
    banner.hidden = false;
    const klass = data.failure_class || 'unknown';
    msg.textContent = (data.rolled_back ? 'Rolled back' : 'Unhealthy') +
      ' (' + klass + '). Auto-apply paused until you dismiss or Undo.';
  }

  async function undoLastRun() {
    if (!sessionId) {
      alert('No AI session yet — run a prompt first, then Undo.');
      return;
    }
    if (!confirm('Rollback all file changes from this AI session?')) return;
    const res = await fetch(base + '/changes/rollback_session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ session_id: sessionId })
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      alert(data.error || 'Rollback failed');
      return;
    }
    alert('Rolled back ' + (data.count || 0) + ' change(s).');
    location.reload();
  }

  document.getElementById('rab-undo-last-run')?.addEventListener('click', undoLastRun);
  document.getElementById('rab-host-banner-undo')?.addEventListener('click', undoLastRun);
  document.getElementById('rab-host-banner-dismiss')?.addEventListener('click', () => {
    const banner = document.getElementById('rab-host-banner');
    if (banner) banner.hidden = true;
  });

  document.querySelectorAll('.rab-change-item[data-change-id]').forEach(item => {
    item.addEventListener('click', async (ev) => {
      if (ev.target.closest('button')) return;
      const res = await fetch(base + '/changes/' + item.dataset.changeId);
      const data = await res.json();
      const diffEl = document.getElementById('rab-diff-detail');
      if (data.diff?.unified) {
        diffEl.innerHTML = '<div class="rab-diff-view">' + data.diff.unified.replace(/^\+/gm, '<span class="rab-diff-add">+</span>').replace(/^-/gm, '<span class="rab-diff-del">-</span>') + '</div>';
      }
    });
  });

  // GitHub PR
  document.getElementById('rab-create-pr')?.addEventListener('click', async () => {
    if (!canPr) {
      openUpgradeModal({ error: 'GitHub PR creation requires Team+', suggested_plan: 'team' });
      return;
    }
    const { data } = await apiFetch('/pull_requests', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: 'AI: ' + document.getElementById('rab-prompt').value.slice(0, 60) })
    });
    if (data.compare_url || data.pr_url) window.open(data.compare_url || data.pr_url, '_blank');
    else if (data.code !== 'plan_required') alert(data.error || JSON.stringify(data));
  });

  // Audit
  document.getElementById('rab-load-audit')?.addEventListener('click', async () => {
    if (!canAudit) {
      openUpgradeModal({ error: 'Audit log requires Team+', suggested_plan: 'team' });
      return;
    }
    const { data } = await apiFetch('/audit');
    document.getElementById('rab-audit-log').textContent = JSON.stringify(data, null, 2);
  });

  const watchedTasks = new Set();

  async function watchTask(id, opts) {
    opts = opts || {};
    if (!id || watchedTasks.has(id)) return;
    watchedTasks.add(id);
    try {
      const res = await fetch(base + '/tasks/' + id + '/stream', {
        method: 'POST',
        headers: { Accept: 'text/event-stream' }
      });
      await consumeSse(res, (event, data) => {
        if (event === 'delta' && data.token) return;
        // Default: background tasks update Tasks panel only — never jump the open chat
        appendEvent(event, data, {
          fromTask: true,
          followInAgent: !!opts.followInAgent
        });
      });
    } catch (e) { /* task may have finished before subscribe */ }
    watchedTasks.delete(id);
    loadTasks();
  }

  function appendHistoryAssistant(content) {
    if (!content) return;
    const turn = ensureTurn();
    setTurnPhase('done');
    turn.reply.hidden = false;
    turn.reply.insertAdjacentHTML('beforeend',
      '<div class="rab-reply-final">' + escapeHtml(String(content).slice(0, 8000)) + '</div>');
    currentTurn = null;
    replyBufferEl = null;
    lastStepKey = '';
  }

  async function loadSessionHistory(id, { silent, force } = {}) {
    if (!id || !streamEl) return false;
    if (running && !force) return false; // never yank the stream mid-run
    const gen = ++historyGen;
    try {
      const res = await fetch(base + '/ai/sessions/' + encodeURIComponent(id));
      if (gen !== historyGen) return false;
      if (res.status === 404) {
        if (!silent) {
          localStorage.removeItem('rab-session-id');
          sessionId = null;
        }
        return false;
      }
      if (!res.ok) throw new Error('Could not load chat (' + res.status + ')');
      const data = await res.json();
      if (gen !== historyGen) return false;
      bindSession(data.id || id, { quiet: true });
      streamEl.innerHTML = '';
      currentTurn = null;
      replyBufferEl = null;
      lastStepKey = '';
      turnFiles = [];
      const msgs = (data.messages || []).filter((m) => m && (m.role === 'user' || m.role === 'assistant') && m.content);
      if (!msgs.length) {
        streamEl.innerHTML = '<div class="rab-empty-chat">Empty thread — ask the agent to start this chat.</div>';
        return true;
      }
      msgs.forEach((m) => {
        if (m.role === 'user') appendUserBubble(m.content);
        else appendHistoryAssistant(m.content);
      });
      streamEl.scrollTop = streamEl.scrollHeight;
      setLive(null);
      if (statusEl) {
        statusEl.className = 'rab-status-idle';
        statusEl.textContent = (data.title || 'Thread') + ' · ' + msgs.length + ' messages';
      }
      return true;
    } catch (e) {
      if (!silent && gen === historyGen) {
        streamEl.insertAdjacentHTML('beforeend',
          '<div class="rab-empty-chat">Could not load previous chat: ' + escapeHtml(e.message) + '</div>');
      }
      return false;
    }
  }

  async function loadSessions() {
    const el = document.getElementById('rab-session-list');
    if (!el) return;
    try {
      const res = await fetch(base + '/ai/sessions');
      const data = await res.json();
      if (!data.sessions?.length) {
        el.innerHTML = '<p class="rab-locked">No previous chats yet — send a prompt to start a thread.</p>';
        return;
      }
      el.innerHTML = data.sessions.map(s =>
        '<div class="rab-tree-item rab-session-item' + (s.id === sessionId ? ' active' : '') + '" data-session="' + s.id + '" style="padding:0.4rem 0.5rem;cursor:pointer;border-bottom:1px solid var(--rab-border)">' +
        '<div style="display:flex;justify-content:space-between;gap:0.35rem;align-items:flex-start">' +
          '<div style="min-width:0">' +
            '<div style="font-weight:600;font-size:0.75rem">' + escapeHtml(s.title || 'Thread') + '</div>' +
            '<div style="font-size:0.68rem;color:var(--rab-muted)">' + escapeHtml((s.preview || '').slice(0, 60)) + '</div>' +
            '<div style="font-size:0.62rem;color:var(--rab-muted);margin-top:0.15rem">' + (s.message_count || 0) + ' msgs</div>' +
          '</div>' +
          '<button type="button" class="rab-btn rab-btn-secondary rab-session-delete" data-delete-session="' + s.id + '" title="Delete chat" style="padding:0.1rem 0.35rem;font-size:0.65rem">×</button>' +
        '</div></div>'
      ).join('');
    } catch (e) {
      el.innerHTML = '<p class="rab-locked">' + e.message + '</p>';
    }
  }

  function openThreadsPanel() {
    document.querySelector('.rab-activity-btn[data-panel="sessions"]')?.click();
  }

  document.getElementById('rab-open-threads')?.addEventListener('click', () => {
    openThreadsPanel();
    loadSessions();
  });

  document.getElementById('rab-session-list')?.addEventListener('click', async (ev) => {
    const del = ev.target.closest('[data-delete-session]');
    if (del) {
      ev.preventDefault();
      ev.stopPropagation();
      const id = del.dataset.deleteSession;
      if (!confirm('Delete this chat thread?')) return;
      await fetch(base + '/ai/sessions/' + encodeURIComponent(id), { method: 'DELETE' });
      if (sessionId === id) {
        sessionId = null;
        localStorage.removeItem('rab-session-id');
        historyGen += 1;
        streamEl.innerHTML = '<div class="rab-empty-chat">Chat deleted. Ask anything to start a new thread.</div>';
      }
      loadSessions();
      return;
    }
    const item = ev.target.closest('[data-session]');
    if (!item) return;
    if (running) {
      alert('Wait for the current run to finish before switching chats.');
      return;
    }
    const id = item.dataset.session;
    document.querySelectorAll('.rab-session-item').forEach(i => i.classList.remove('active'));
    item.classList.add('active');
    document.querySelector('[data-tab="agent"]')?.click();
    await loadSessionHistory(id, { force: true });
  });

  document.getElementById('rab-new-session')?.addEventListener('click', async () => {
    if (running) {
      alert('Wait for the current run to finish before starting a new chat.');
      return;
    }
    const res = await fetch(base + '/ai/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
    const data = await res.json();
    historyGen += 1;
    bindSession(data.id, { quiet: true });
    streamEl.innerHTML = '<div class="rab-empty-chat">New chat — ask the agent…</div>';
    currentTurn = null;
    loadSessions();
    document.querySelector('[data-tab="agent"]')?.click();
  });

  async function loadTasks() {
    const el = document.getElementById('rab-task-list');
    if (!el) return;
    try {
      const res = await fetch(base + '/tasks');
      const data = await res.json();
      if (!data.tasks?.length) { el.innerHTML = '<p class="rab-locked">No tasks queued</p>'; return; }
      el.innerHTML = data.tasks.map(t => {
        const pr = t.compare_url || t.pr_url;
        return '<div class="rab-change-item" data-task-id="' + t.id + '">' +
          '<div class="rab-change-path">' + t.status + (t.branch ? ' · ' + t.branch : '') + '</div>' +
          '<div style="font-size:0.72rem">' + (t.description || '').slice(0, 60) + '</div>' +
          (pr ? '<a href="' + pr + '" target="_blank" style="font-size:0.68rem">PR</a>' : '') +
          '</div>';
      }).join('');
      // Silent watch — updates Tasks list only; does not steal the Agent chat
      data.tasks.filter(t => t.status === 'running' || t.status === 'queued').forEach(t => watchTask(t.id, { followInAgent: false }));
    } catch (e) { el.innerHTML = '<p class="rab-locked">' + e.message + '</p>'; }
  }

  document.getElementById('rab-refresh-tasks')?.addEventListener('click', loadTasks);
  loadTasks();
  loadSessions();
  // Restore previous chat into the Agent stream (survives refresh)
  if (sessionId) {
    loadSessionHistory(sessionId, { silent: true }).then((ok) => {
      if (!ok) loadSessions();
    });
  }
  setInterval(loadTasks, 8000);
})();
</script>
