<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rails AI Build — Dashboard</title>
  <style>
    :root { --red: #d30001; --bg: #0f0f1a; --card: #1a1a2e; --text: #e0e0e0; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; background: var(--bg); color: var(--text); padding: 2rem; }
    h1 { color: var(--red); margin-bottom: 0.5rem; }
    .plan { display: inline-block; background: var(--red); padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.85rem; margin-bottom: 2rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
    .card { background: var(--card); border-radius: 12px; padding: 1.5rem; border: 1px solid #333; }
    .card h2 { font-size: 1rem; color: #aaa; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .skill { padding: 0.5rem 0; border-bottom: 1px solid #333; }
    .skill strong { color: white; }
    form { margin-top: 1rem; }
    input, select, textarea { width: 100%; padding: 0.75rem; margin: 0.5rem 0; background: #111; border: 1px solid #444; color: white; border-radius: 6px; }
    button { background: var(--red); color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; width: 100%; margin-top: 0.5rem; }
    #result { margin-top: 1rem; padding: 1rem; background: #111; border-radius: 6px; white-space: pre-wrap; min-height: 60px; }
    .pending { color: #fbbf24; }
  </style>
</head>
<body>
  <h1>⬥ Rails AI Build</h1>
  <span class="plan"><%= @plan.to_s.upcase %> PLAN</span>

  <div class="grid">
    <div class="card">
      <h2>Ask Agent</h2>
      <form id="chat-form">
        <select id="skill">
          <option value="">No skill</option>
          <% @skills.each do |s| %>
            <option value="<%= s[:name] %>"><%= s[:name] %> — <%= s[:description].truncate(40) %></option>
          <% end %>
        </select>
        <textarea id="prompt" rows="3" placeholder="Add a health check endpoint..."></textarea>
        <button type="submit">Run Agent</button>
      </form>
      <div id="result"></div>
    </div>

    <div class="card">
      <h2>Pending Changes</h2>
      <% if @pending.any? %>
        <% @pending.each do |c| %>
          <div class="skill pending">
            <strong><%= c.path %></strong>
            <button onclick="applyChange('<%= c.id %>')" style="width:auto;margin-left:1rem;padding:0.25rem 0.75rem;">Apply</button>
          </div>
        <% end %>
        <button onclick="applyAll()" style="margin-top:1rem;">Apply All</button>
      <% else %>
        <p style="color:#666;">No pending changes</p>
      <% end %>
    </div>

    <div class="card">
      <h2>Features</h2>
      <% @features.each do |name, enabled| %>
        <div class="skill"><%= enabled ? "✅" : "🔒" %> <%= name.to_s.humanize %></div>
      <% end %>
      <% if @features[:analytics] %>
        <button onclick="loadAnalytics()" style="margin-top:1rem;">Load Analytics</button>
        <div id="analytics"></div>
      <% end %>
    </div>
  </div>

  <script>
    const base = window.location.pathname.replace(/\/ui.*/, '');

    document.getElementById('chat-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const result = document.getElementById('result');
      result.textContent = 'Running...';
      const res = await fetch(base + '/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: document.getElementById('prompt').value,
          skill: document.getElementById('skill').value || undefined
        })
      });
      const data = await res.json();
      result.textContent = data.content || data.error || JSON.stringify(data, null, 2);
      if (data.pending_changes?.length) location.reload();
    });

    async function applyChange(id) {
      await fetch(base + '/changes/' + id + '/apply', { method: 'POST' });
      location.reload();
    }

    async function applyAll() {
      await fetch(base + '/changes/apply_all', { method: 'POST' });
      location.reload();
    }

    async function loadAnalytics() {
      const res = await fetch(base + '/analytics');
      const data = await res.json();
      document.getElementById('analytics').textContent = JSON.stringify(data, null, 2);
    }
  </script>
</body>
</html>
