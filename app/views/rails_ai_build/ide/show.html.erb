<% content_for :title do %>Rails AI Build IDE<% end %>

<% ide_base = (request.script_name.presence || request.path.sub(%r{/ui/ide/?.*\z}, '')).to_s.sub(%r{/\z}, '') %>
<div class="rab-ide" id="rab-ide"
     data-base="<%= ide_base %>"
     data-streaming="<%= @features[:streaming] %>"
     data-pr="<%= @features[:pr_creation] %>"
     data-audit="<%= @features[:audit_log] %>"
     data-auto-apply="<%= !RailsAiBuild.configuration.diff_preview %>"
     data-needs-wizard="<%= @activation[:needs_wizard] %>"
     data-upgrade-url="<%= @upgrade_url %>"
     data-plan="<%= @plan %>">

  <header class="rab-topbar">
    <div class="rab-logo">⬥ Rails AI Build <span>IDE v<%= @version %></span></div>
    <% if @git[:available] && @git[:branch].present? %>
      <span class="rab-branch">⎇ <%= @git[:branch] %></span>
    <% end %>
    <button type="button" class="rab-badge rab-badge-plan" id="rab-plan-badge" title="Upgrade plan"><%= @plan_name %></button>
    <% if @plan == :enterprise %>
      <span class="rab-badge rab-badge-enterprise">Enterprise</span>
    <% end %>
    <% if @features[:pr_creation] %>
      <span class="rab-badge rab-badge-github">GitHub</span>
    <% end %>
    <% if @enterprise[:rbac_enabled] %>
      <span class="rab-badge rab-badge-role"><%= @enterprise[:role] %></span>
    <% end %>
    <div class="rab-spacer"></div>
    <button type="button" class="rab-btn rab-btn-secondary" id="rab-open-wizard" style="padding:0.25rem 0.55rem;font-size:0.7rem">Activate</button>
    <select id="rab-theme" title="Theme">
      <option value="dark">Dark</option>
      <option value="light">Light</option>
      <option value="enterprise">Enterprise</option>
    </select>
    <select id="rab-provider" title="Provider">
      <% @providers.each do |p| %>
        <option value="<%= p %>"><%= p %></option>
      <% end %>
    </select>
    <a href="<%= request.path.sub(%r{/ui/ide.*}, '/ui/demo') %>">Demo</a>
    <a href="<%= request.path.sub(%r{/ui/ide.*}, '/ui') %>">Dashboard</a>
  </header>

  <div class="rab-wizard-overlay" id="rab-wizard" hidden>
    <div class="rab-wizard-card">
      <h2>Activate Rails AI Build</h2>
      <p class="rab-wizard-sub">Same loop as Cursor — pick one door to start coding with AI in this app.</p>
      <div class="rab-wizard-doors">
        <button type="button" class="rab-wizard-door active" data-door="byok">BYOK</button>
        <button type="button" class="rab-wizard-door" data-door="cloud">Cloud key</button>
        <button type="button" class="rab-wizard-door" data-door="license">License</button>
      </div>

      <div class="rab-wizard-pane" id="rab-door-byok">
        <label>OpenAI / Anthropic / NVIDIA key</label>
        <select id="rab-wizard-provider">
          <option value="nvidia">NVIDIA (free NIM)</option>
          <option value="openai">OpenAI</option>
          <option value="anthropic">Anthropic</option>
        </select>
        <input id="rab-wizard-key" type="password" placeholder="Paste API key" autocomplete="off" />
        <button type="button" class="rab-btn rab-btn-primary" id="rab-wizard-save-key">Save key &amp; continue</button>
      </div>

      <div class="rab-wizard-pane" id="rab-door-cloud" hidden>
        <label>Rails AI Cloud API key</label>
        <input id="rab-wizard-cloud" type="password" placeholder="rab_cloud_…" autocomplete="off" />
        <p class="rab-wizard-hint">Hosted models without your own OpenAI/Anthropic key. Get one at railsaibuild.com.</p>
        <button type="button" class="rab-btn rab-btn-primary" id="rab-wizard-save-cloud">Save cloud key</button>
      </div>

      <div class="rab-wizard-pane" id="rab-door-license" hidden>
        <label>Signed license token</label>
        <textarea id="rab-wizard-license" rows="3" placeholder="Paste license token from your purchase"></textarea>
        <button type="button" class="rab-btn rab-btn-primary" id="rab-wizard-save-license">Activate license</button>
      </div>

      <p class="rab-wizard-status" id="rab-wizard-status"></p>
      <div class="rab-wizard-actions">
        <button type="button" class="rab-btn rab-btn-secondary" id="rab-wizard-skip">Skip for now</button>
        <button type="button" class="rab-btn rab-btn-secondary" id="rab-wizard-close">Close</button>
      </div>
    </div>
  </div>

  <div class="rab-modal-overlay" id="rab-upgrade-modal" hidden>
    <div class="rab-modal-card">
      <h2>Upgrade required</h2>
      <p id="rab-upgrade-message">This feature needs a higher plan.</p>
      <p class="rab-wizard-hint">Suggested: <strong id="rab-upgrade-plan">Pro</strong></p>
      <div class="rab-wizard-actions">
        <button type="button" class="rab-btn rab-btn-primary" id="rab-upgrade-checkout">Checkout</button>
        <a class="rab-btn rab-btn-secondary" id="rab-upgrade-pricing" href="<%= @upgrade_url %>" target="_blank" rel="noopener">View pricing</a>
        <button type="button" class="rab-btn rab-btn-secondary" id="rab-upgrade-close">Not now</button>
      </div>
      <p class="rab-wizard-status" id="rab-upgrade-status"></p>
    </div>
  </div>

  <div class="rab-workspace">
    <nav class="rab-activity">
      <button class="rab-activity-btn active" data-panel="files" title="Explorer">📁</button>
      <button class="rab-activity-btn" data-panel="sessions" title="Threads">💬</button>
      <button class="rab-activity-btn" data-panel="agent" title="Agent">🤖</button>
      <% if @features[:git_integration] %><button class="rab-activity-btn" data-panel="git" title="Git">⎇</button><% end %>
    </nav>

    <aside class="rab-sidebar" id="rab-sidebar-files">
      <div class="rab-sidebar-header">Explorer</div>
      <div class="rab-sidebar-body" id="rab-file-tree">
        <p class="rab-locked">Loading workspace…</p>
      </div>
    </aside>

    <aside class="rab-sidebar" id="rab-sidebar-sessions" style="display:none">
      <div class="rab-sidebar-header" style="display:flex;justify-content:space-between;align-items:center">
        <span>Threads</span>
        <button type="button" class="rab-btn rab-btn-secondary" id="rab-new-session" style="padding:0.2rem 0.4rem;font-size:0.65rem">New</button>
      </div>
      <div class="rab-sidebar-body" id="rab-session-list">
        <p class="rab-locked">Loading threads…</p>
      </div>
    </aside>

    <main class="rab-center">
      <div class="rab-tabs" id="rab-editor-tabs">
        <button class="rab-tab active" data-tab="editor">Editor</button>
        <button class="rab-tab" data-tab="agent">Agent</button>
      </div>

      <div class="rab-editor" id="rab-editor">
        <div class="rab-editor-empty">Select a file from the explorer, or ask the agent below.</div>
      </div>

      <div class="rab-agent-panel" id="rab-agent-panel">
        <div class="rab-agent-header">
          <span>Agent — Cursor-style SSE stream</span>
          <span id="rab-agent-status"></span>
        </div>
        <div class="rab-stream" id="rab-stream"></div>
        <form class="rab-prompt-bar" id="rab-prompt-form">
          <select id="rab-mode" title="Mode">
            <option value="stream">Agent</option>
            <option value="build">Build (verify)</option>
            <option value="composer">Composer</option>
            <option value="queue">Queue task</option>
          </select>
          <select id="rab-skill">
            <option value="">No skill</option>
            <% @skills.each do |s| %>
              <option value="<%= s[:name] %>"><%= s[:name] %></option>
            <% end %>
          </select>
          <textarea id="rab-prompt" placeholder="Ask the agent… (e.g. Add a health check endpoint)" rows="1"></textarea>
          <button type="submit" class="rab-btn rab-btn-primary" id="rab-run-btn">Run</button>
        </form>
      </div>
    </main>

    <aside class="rab-right">
      <div class="rab-right-tabs">
        <button class="rab-right-tab" data-right="tasks">Tasks</button>
        <button class="rab-right-tab active" data-right="changes">Changes</button>
        <button class="rab-right-tab" data-right="git">Git</button>
        <button class="rab-right-tab" data-right="doctor">Doctor</button>
        <button class="rab-right-tab" data-right="enterprise">Enterprise</button>
      </div>
      <div class="rab-right-body">
        <section id="rab-panel-tasks" style="display:none">
          <button class="rab-btn rab-btn-secondary" id="rab-refresh-tasks" style="width:100%;margin-bottom:0.5rem">Refresh</button>
          <div id="rab-task-list"><p class="rab-locked">No tasks queued</p></div>
        </section>

        <section id="rab-panel-changes">
          <h3 style="font-size:0.7rem;color:var(--rab-muted);margin-bottom:0.5rem">PENDING DIFFS</h3>
          <% if @pending.any? %>
            <% @pending.each do |c| %>
              <div class="rab-change-item" data-change-id="<%= c.id %>">
                <div class="rab-change-path"><%= c.path %></div>
                <div style="margin-top:0.4rem;display:flex;gap:0.4rem">
                  <button class="rab-btn rab-btn-secondary rab-apply-btn" data-id="<%= c.id %>" style="padding:0.25rem 0.5rem;font-size:0.7rem">Apply</button>
                  <button class="rab-btn rab-btn-secondary rab-reject-btn" data-id="<%= c.id %>" style="padding:0.25rem 0.5rem;font-size:0.7rem">Reject</button>
                </div>
              </div>
            <% end %>
            <button class="rab-btn rab-btn-accent" id="rab-apply-all" style="width:100%;margin-top:0.5rem">Apply All</button>
          <% else %>
            <% if RailsAiBuild.configuration.diff_preview %>
              <p class="rab-locked">No pending changes yet. Run the agent to queue file diffs.</p>
            <% else %>
              <p class="rab-locked">Auto-apply is on — file writes are applied immediately. Enable <code>diff_preview</code> in the initializer to review before apply.</p>
            <% end %>
          <% end %>
          <div id="rab-diff-detail" style="margin-top:1rem"></div>
        </section>

        <section id="rab-panel-git" style="display:none">
          <% if @git[:available] %>
            <p><strong>Branch:</strong> <span class="rab-branch"><%= @git[:branch] %></span></p>
            <h3 style="font-size:0.7rem;color:var(--rab-muted);margin:0.75rem 0 0.5rem">CHANGED FILES</h3>
            <% @git[:changed_files].to_a.first(20).each do |f| %>
              <div class="rab-git-file"><%= f %></div>
            <% end %>
            <% if @features[:pr_creation] %>
              <button class="rab-btn rab-btn-github" id="rab-create-pr" style="width:100%;margin-top:1rem">Create GitHub PR</button>
            <% else %>
              <p class="rab-locked" style="margin-top:1rem">GitHub PR — Team+ plan required</p>
            <% end %>
          <% else %>
            <p class="rab-locked">Git not available in this workspace.</p>
          <% end %>
        </section>

        <section id="rab-panel-doctor" style="display:none">
          <button class="rab-btn rab-btn-secondary" id="rab-refresh-doctor" style="width:100%;margin-bottom:0.5rem">Run doctor</button>
          <div id="rab-doctor-summary" class="rab-doctor-summary">Checking…</div>
          <div id="rab-doctor-list"></div>
        </section>

        <section id="rab-panel-enterprise" style="display:none">
          <div class="rab-enterprise-item">
            <strong>Plan:</strong> <%= @plan_name %>
            <% if @plan == :enterprise %><span class="rab-badge rab-badge-enterprise" style="margin-left:0.5rem">SSO · RBAC · SOC2</span><% end %>
          </div>
          <div class="rab-enterprise-item">
            <strong>Entitlement:</strong> <%= @activation[:entitlement_source] %>
            <% if @activation[:license_present] %> · license<% end %>
          </div>
          <% @features.each do |name, enabled| %>
            <div class="rab-enterprise-item">
              <span class="<%= enabled ? 'rab-feature-on' : 'rab-feature-off' %>"><%= enabled ? '✓' : '○' %></span>
              <%= name.to_s.humanize %>
              <% unless enabled %>
                <button type="button" class="rab-upgrade-link" data-feature="<%= name %>">Upgrade</button>
              <% end %>
            </div>
          <% end %>
          <% if @features[:audit_log] %>
            <button class="rab-btn rab-btn-secondary" id="rab-load-audit" style="width:100%;margin-top:0.75rem">Load audit log</button>
            <pre id="rab-audit-log" class="rab-diff-view" style="margin-top:0.5rem;max-height:160px"></pre>
          <% end %>
          <% if @features[:sso] %>
            <p style="margin-top:0.75rem;font-size:0.72rem;color:var(--rab-muted)">SSO: <code>GET /auth/saml</code> — mount behind your IdP</p>
          <% end %>
          <button type="button" class="rab-btn rab-btn-accent" id="rab-open-upgrade" style="width:100%;margin-top:0.75rem">Upgrade plan</button>
        </section>
      </div>
    </aside>
  </div>
</div>

<% content_for :scripts do %>
  <%= render "rails_ai_build/shared/ide" %>
<% end %>
